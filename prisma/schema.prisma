generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// -----------------------------------------------------------------------------
// User & Authentication
// -----------------------------------------------------------------------------

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String?         @unique
  emailVerified  DateTime?
  username       String          @unique
  image          String?
  followerCount  Int             @default(0)
  followingCount Int             @default(0)
  joindate       DateTime        @default(now())
  password       String?
  
  // Relations
  accounts       Account[]
  sessions       Session[]
  posts          Posts[]
  comments       Comments[]
  likes          Likes[]
  clikes         Comment_Likes[]
  rerankings     ReRankings[]
  rlikes         ReRanking_Likes[]
  following      Follow[]        @relation("FollowingRelation")
  followers      Follow[]        @relation("FollowerRelation")
  adminGroups    Groups[]        @relation("GroupAdmins")
  memberGroups   Groups[]        @relation("GroupMembers")
  reports        Reports[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         Int      @id @default(autoincrement())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Follow {
  followerId  String
  followingId String
  follower    User   @relation("FollowingRelation", fields: [followerId], references: [id], onDelete: Cascade)
  following   User   @relation("FollowerRelation", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

// -----------------------------------------------------------------------------
// Posts & Metadata
// -----------------------------------------------------------------------------

enum ReRankType {
  NONE
  REORDER
  FULL
}

model Posts {
  id          String         @id @default(cuid())
  title       String
  items       Json
  itemCount   Int
  reRankType  ReRankType     @default(NONE)
  authorId    String?
  username    String?
  description String?
  category    String
  groupId     String?
  private     Boolean        @default(false)
  
  // Relations
  metadata    Post_Metadata?
  author      User?          @relation(fields: [authorId], references: [id])
  group       Groups?        @relation(fields: [groupId], references: [id])
  comments    Comments[]
  rerankings  ReRankings[]
}

enum PostStatus { 
  UPLOADING 
  PROCESSING 
  READY 
  FAILED 
}

model Post_Metadata {
  postId          String     @unique
  images          Boolean    @default(false)
  videos          Boolean    @default(false)
  status          PostStatus @default(READY) 
  processingError String?  
  likes           Int        @default(0)
  views           Int        @default(0)
  rerankCount     Int        @default(0)
  date            DateTime   @default(now())
  post            Posts      @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Likes {
  userId String
  postId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}

// -----------------------------------------------------------------------------
// Groups
// -----------------------------------------------------------------------------

model Groups {
  id         String   @id @default(cuid())
  name       String
  password   String?
  population Int      @default(1)
  invite     Boolean
  private    Boolean
  bannerimg  Boolean
  profileimg Boolean
  date       DateTime @default(now())
  
  // Relations
  posts      Posts[]
  admins     User[]   @relation("GroupAdmins")
  members    User[]   @relation("GroupMembers")
}

// -----------------------------------------------------------------------------
// Comments
// -----------------------------------------------------------------------------

model Comments {
  id       String   @id @default(cuid())
  text     String
  likes    Int      @default(0)
  date     DateTime @default(now())
  parentId String?
  username String?
  postId   String
  userId   String
  replies  Int      @default(0)
  
  // Relations
  post     Posts    @relation(fields: [postId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}

model Comment_Likes {
  userId    String
  commentId String
  user      User   @relation(fields: [userId], references: [id])

  @@unique([userId, commentId])
}

// -----------------------------------------------------------------------------
// Re-rankings
// -----------------------------------------------------------------------------

model ReRankings {
  id              String   @id @default(cuid())
  postId          String
  userId          String?
  items           Json
  normalizedItems Json     @default("[]")
  rankMap         Int[]
  likes           Int      @default(0)
  createdAt       DateTime @default(now())
  
  // Relations
  post      Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  rlikes    ReRanking_Likes[]
  @@unique([userId, postId])
  @@index([postId])
  @@index([createdAt])
}

model ReRanking_Likes {
  userId      String
  rerankingId String
  user        User       @relation(fields: [userId], references: [id])
  reranking   ReRankings @relation(fields: [rerankingId], references: [id], onDelete: Cascade)

  @@unique([userId, rerankingId])
}

// -----------------------------------------------------------------------------
// System & Administrative
// -----------------------------------------------------------------------------

model Reports {
  userId   String?
  report   String
  reportID String   @id @default(cuid())
  date     DateTime @default(now())
  user     User?    @relation(fields: [userId], references: [id])
}

model AlgoliaMetadata {
  id             String   @id @default("last-update")
  lastPost DateTime @default(now())
  lastGroup DateTime @default(now())
  lastUser  DateTime @default(now())
}